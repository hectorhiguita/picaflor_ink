# ─── Base de datos ────────────────────────────────────────────────────────────
# Cadena de conexión PostgreSQL
# Docker Compose local: postgresql://picaflor:picaflor@localhost:5433/picaflor_ink
DATABASE_URL="postgresql://picaflor:picaflor@localhost:5433/picaflor_ink?schema=public"

# ─── Autenticación ────────────────────────────────────────────────────────────
# Secreto para firmar sesiones (Auth.js / NextAuth)
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-seguro"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Pagos — Wompi ────────────────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""

# ─── Storage — AWS S3 ─────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="picaflor-ink-assets"

# ─── Email transaccional ──────────────────────────────────────────────────────
# Dirección remitente (p. ej. noreply@picaflorink.shop)
EMAIL_FROM="noreply@picaflorink.shop"
# API key del proveedor (Amazon SES, Resend, etc.)
EMAIL_PROVIDER_API_KEY=""

# ─── Redes sociales ───────────────────────────────────────────────────────────
# Token de acceso a la API de Instagram para el social feed
INSTAGRAM_ACCESS_TOKEN=""
